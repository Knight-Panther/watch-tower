# ═══════════════════════════════════════════════════════════════════════════════
# Watch Tower — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file: cp .env.production.template .env
# Then fill in all values marked with CHANGEME
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Inside Docker network, use service name "postgres"
POSTGRES_USER=watchtower
POSTGRES_PASSWORD=CHANGEME_STRONG_DB_PASSWORD
POSTGRES_DB=watchtower
DATABASE_URL=postgres://watchtower:CHANGEME_STRONG_DB_PASSWORD@postgres:5432/watchtower

# ─── Redis ────────────────────────────────────────────────────────────────────
# Inside Docker network, use service name "redis"
REDIS_HOST=redis
REDIS_PORT=6379

# ─── API ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_KEY=CHANGEME_RANDOM_API_KEY
PORT=3001

# ─── Embeddings (OpenAI) ─────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGEME_OPENAI_KEY
EMBEDDING_MODEL=text-embedding-3-small
SIMILARITY_THRESHOLD=0.85

# ─── LLM Brain (Scoring) ─────────────────────────────────────────────────────
# Primary provider: "claude" | "openai" | "deepseek"
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=CHANGEME_ANTHROPIC_KEY
# DEEPSEEK_API_KEY=sk-...

# Model overrides (optional — sensible defaults built in)
# LLM_CLAUDE_MODEL=claude-sonnet-4-20250514
# LLM_OPENAI_MODEL=gpt-4o-mini
# LLM_DEEPSEEK_MODEL=deepseek-chat

# Fallback provider (optional)
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-4o-mini

# Auto-approve/reject thresholds (1-5)
LLM_AUTO_APPROVE_THRESHOLD=5
LLM_AUTO_REJECT_THRESHOLD=2

# ─── Translation (Georgian) ──────────────────────────────────────────────────
GOOGLE_AI_API_KEY=CHANGEME_GOOGLE_AI_KEY

# ─── Image Generation + R2 Storage ───────────────────────────────────────────
# Cloudflare R2 (for AI-generated news card images)
# R2_ACCOUNT_ID=CHANGEME
# R2_ACCESS_KEY_ID=CHANGEME
# R2_SECRET_ACCESS_KEY=CHANGEME
# R2_BUCKET_NAME=CHANGEME
# R2_PUBLIC_URL=CHANGEME

# ─── Social Platforms ─────────────────────────────────────────────────────────
# Telegram
TELEGRAM_BOT_TOKEN=CHANGEME_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGEME_CHAT_ID

# Facebook Page
FB_PAGE_ID=CHANGEME
FB_ACCESS_TOKEN=CHANGEME

# LinkedIn
LINKEDIN_AUTHOR_TYPE=person
LINKEDIN_AUTHOR_ID=CHANGEME
LINKEDIN_ACCESS_TOKEN=CHANGEME

# ─── Security ────────────────────────────────────────────────────────────────
MAX_FEED_SIZE_MB=5
MAX_ARTICLES_PER_FETCH=100
MAX_ARTICLES_PER_SOURCE_DAILY=500
API_RATE_LIMIT_PER_MINUTE=200

# ─── Domain & URLs ───────────────────────────────────────────────────────────
# Your production domain (used for CORS, frontend API URL, OAuth callbacks)
DOMAIN=CHANGEME_yourdomain.com
ALLOWED_ORIGINS=https://CHANGEME_yourdomain.com

# Frontend env vars (baked into static build at docker build time)
VITE_API_URL=https://CHANGEME_yourdomain.com/api
VITE_API_KEY=CHANGEME_SAME_AS_API_KEY

# ─── Nginx Basic Auth ────────────────────────────────────────────────────────
# Dashboard login credentials (htpasswd format)
# Generate with: htpasswd -nb admin yourpassword
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=CHANGEME_DASHBOARD_PASSWORD

# ─── SSL (Let's Encrypt) ─────────────────────────────────────────────────────
# Email for certificate expiry notifications
CERTBOT_EMAIL=CHANGEME_your@email.com
