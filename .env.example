# Environment (development | production)
NODE_ENV=development
LOG_LEVEL=info                              # debug | info | warn | error

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgres://watchtower:watchtower@127.0.0.1:5432/watchtower

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# API Key (optional, for protecting API endpoints)
API_KEY=local-dev-key
PORT=3001

# Embeddings (OpenAI)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
SIMILARITY_THRESHOLD=0.85

# ─── LLM Brain (Stage 3: Scoring) ─────────────────────────────────────────────
# Provider API Keys (add keys for providers you want to use)
ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# Note: OPENAI_API_KEY above is shared between embeddings and LLM if using OpenAI

# Primary LLM provider: "claude" | "openai" | "deepseek"
LLM_PROVIDER=claude

# Per-provider model selection (optional, sensible defaults)
# LLM_CLAUDE_MODEL=claude-sonnet-4-20250514
# LLM_OPENAI_MODEL=gpt-4o-mini
# LLM_DEEPSEEK_MODEL=deepseek-chat

# Fallback provider (optional, used if primary API fails)
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-4o-mini

# Auto-approve/reject thresholds (1-5 scale)
LLM_AUTO_APPROVE_THRESHOLD=5
LLM_AUTO_REJECT_THRESHOLD=2

# ─── Social Platforms (Stage 4: Distribution) ────────────────────────────────

# Telegram
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
# Chat ID: use @userinfobot or forward a message to @getidsbot
TELEGRAM_CHAT_ID=-1001234567890

# Facebook Page
# Get from: https://developers.facebook.com/tools/explorer/
# Page ID: Facebook Page → About → Page ID
# Access Token: Generate Page Access Token with pages_manage_posts permission
FB_PAGE_ID=your-page-id
FB_ACCESS_TOKEN=your-page-access-token

# LinkedIn (Personal Profile or Organization)
# Get from: https://www.linkedin.com/developers/
# 1. Create app → Add "Sign In with LinkedIn using OpenID Connect" product
# 2. Add "Share on LinkedIn" product (for w_member_social scope)
# 3. OAuth flow: authorize with scope=openid%20profile%20w_member_social
# 4. Exchange code for token, decode id_token to get your person ID (sub claim)
#
# AUTHOR_TYPE: "person" for personal profile, "organization" for company page
# AUTHOR_ID: person ID from id_token (e.g., "abc123XYZ") or org ID from company URL
LINKEDIN_AUTHOR_TYPE=person
LINKEDIN_AUTHOR_ID=your-author-id
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token


# ─── Translation (Georgian) ───────────────────────────────────────────────────

# Google AI (Gemini) — primary translation provider
# GOOGLE_AI_API_KEY=...

# ─── Image Generation + R2 Storage ───────────────────────────────────────────

# Cloudflare R2 (for storing AI-generated news card images)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=...
# R2_PUBLIC_URL=...

# ─── Security Configuration ───────────────────────────────────────────────────

# Feed Limits (Layer 3 & 5)
MAX_FEED_SIZE_MB=5                              # Max RSS feed size in megabytes
MAX_ARTICLES_PER_FETCH=100                      # Max articles per single fetch
MAX_ARTICLES_PER_SOURCE_DAILY=500               # Max articles per source per day

# CORS (Layer 6)
ALLOWED_ORIGINS=http://localhost:5173           # Comma-separated allowed origins

# API Rate Limiting (Layer 7)
API_RATE_LIMIT_PER_MINUTE=200                   # Global API rate limit

# Frontend
VITE_API_URL=http://localhost:3001
VITE_API_KEY=local-dev-key
