{
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(npm install)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run db:*)",
      "Bash(docker ps:*)",
      "Bash(docker stop:*)",
      "Bash(docker rm:*)",
      "Bash(docker compose:*)",
      "Bash(docker network ls:*)",
      "Bash(docker volume ls:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker network rm:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(npm run db:push:*)",
      "Bash(npm install:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(powershell -Command:*)",
      "Bash(npm run infra:up:*)",
      "Bash(node -e:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ -f package.json ]] && npm run test:quick --silent >/dev/null 2>&1; then echo '✅ Tests passed'; else echo '⚠️ Tests may need attention'; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_COMMAND\" | grep -qE '^git\\s+commit'; then python \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secret-scanner.py 2>&1; fi"
          }
        ]
      }
    ]
  }
}
