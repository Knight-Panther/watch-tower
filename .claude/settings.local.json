            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_COMMAND\" | grep -qE '^git\\s+commit'; then python \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secret-scanner.py 2>&1; fi"
