{
  "name": "watch-tower",
  "version": "1.0.0",
  "description": "Media Watch Tower monorepo",
  "private": true,
  "type": "commonjs",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "db:generate": "npm --workspace @watch-tower/db run generate",
    "db:migrate": "npm --workspace @watch-tower/db run migrate",
    "db:push": "npm --workspace @watch-tower/db run push",
    "db:studio": "npm --workspace @watch-tower/db run studio",
    "db:seed": "npm --workspace @watch-tower/db run seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "build": "turbo run build",
    "predev": "node scripts/kill-ports.mjs",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@watch-tower/api",
    "dev:worker": "turbo run dev --filter=@watch-tower/worker",
    "dev:frontend": "turbo run dev --filter=@watch-tower/frontend",
    "lint": "eslint \"packages/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json}\"",
    "test": "vitest run && tsx tests/setup/save-results.ts all tests/results/.vitest-output.json",
    "test:unit": "vitest run tests/unit && tsx tests/setup/save-results.ts unit tests/results/.vitest-output.json",
    "test:integration": "vitest run tests/integration && tsx tests/setup/save-results.ts integration tests/results/.vitest-output.json",
    "test:e2e": "vitest run tests/e2e && tsx tests/setup/save-results.ts e2e tests/results/.vitest-output.json",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run --coverage",
    "test:compare": "tsx tests/reports/compare.ts",
    "test:summary": "tsx tests/reports/summary.ts",
    "test:diagnostics": "tsx tests/diagnostics/health-check.ts",
    "test:audit": "tsx tests/diagnostics/pipeline-audit.ts",
    "quality:deadcode": "knip",
    "quality:duplicates": "jscpd packages/ --output tests/results",
    "quality:all": "npm run lint && npm run quality:deadcode && npm run quality:duplicates",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.0",
    "turbo": "^2.5.0",
    "vitest": "^4.0.18"
  }
}
